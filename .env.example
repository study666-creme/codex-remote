# Web defaults. These are public values bundled into the deployed static site.
VITE_CODEX_REMOTE_DEFAULT_AGENT_URL=https://agent.example.com
VITE_CODEX_REMOTE_SOURCE_URL=https://github.com/study666-creme/codex-remote
VITE_BASE_PATH=/
# Only set this for private deployments. Do not publish a real bridge token in a public demo.
VITE_CODEX_REMOTE_DEFAULT_TOKEN=

# Bridge defaults. Run these on the machine that owns the Codex environment.
CODEX_REMOTE_HOST=127.0.0.1
PORT=17371
CODEX_REMOTE_PUBLIC_URL=https://agent.example.com
CODEX_REMOTE_TOKEN=replace-with-a-long-random-secret
CODEX_REMOTE_WORKSPACE=/path/to/project
CODEX_REMOTE_ALLOWED_ORIGINS=https://your-web.example.com
